# ReconAI — environment template
# Copy to .env.local and fill in real values. Never commit .env.local.

# Anthropic (chat)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5

# OpenAI (embeddings only — text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBED_MODEL=your-openai-embed-model
OPENAI_MODEL=your-openai-model

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Neo4j AuraDB
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=your-neo4j-username
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=your-neo4j-database

# App
NEXT_PUBLIC_APP_NAME=ReconAI
