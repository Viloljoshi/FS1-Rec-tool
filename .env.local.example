# ReconAI — environment template
# Copy to .env.local and fill in values. Never commit .env.local.

# Anthropic (chat)
# Per-seam routing: Sonnet for reasoning-heavy seams (tiebreak, schema
# inference, pipeline suggest, rule drafts, NL search). Haiku for simpler
# high-volume seams (explain-break, next-best-action, workspace summary,
# dashboard narrative). See lib/ai/anthropic.ts TIER_BY_CALL_TYPE.
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
# ANTHROPIC_MODEL is optional back-compat alias for ANTHROPIC_MODEL_SONNET.

# OpenAI (embeddings only — text-embedding-3-small, 1536 dims)
# Anthropic has no embeddings API; we keep OpenAI for counterparty embedding.
OPENAI_API_KEY=sk-proj-...
OPENAI_EMBED_MODEL=text-embedding-3-small

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Neo4j AuraDB
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USERNAME=<your-aura-instance-id>
NEO4J_PASSWORD=...
NEO4J_DATABASE=<your-aura-instance-id>

# App
NEXT_PUBLIC_APP_NAME=ReconAI
